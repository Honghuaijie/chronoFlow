# ChronoFlow deployment configuration

# Images used by docker-compose.image.yml. Override these after publishing your own images.
CHRONOFLOW_ADMIN_IMAGE=ghcr.io/your-name/chronoflow-admin:latest
CHRONOFLOW_EXEC_IMAGE=ghcr.io/your-name/chronoflow-exec:latest
CHRONOFLOW_UI_IMAGE=ghcr.io/your-name/chronoflow-ui:latest

# Host ports
CHRONOFLOW_UI_PORT=5173
CHRONOFLOW_ADMIN_HTTP_PORT=10003
CHRONOFLOW_ADMIN_GRPC_PORT=11003
CHRONOFLOW_EXEC_HTTP_PORT=10004
CHRONOFLOW_EXEC_GRPC_PORT=11004
MYSQL_HOST_PORT=3306

# MySQL
# For the bundled MySQL service, keep DB_HOST=mysql and DB_PORT=3306.
# For an external MySQL, set DB_HOST to host.docker.internal, a LAN IP, or a DNS name.
DB_HOST=mysql
DB_PORT=3306
DB_NAME=chronoflow
DB_USER=chronoflow
DB_PASSWORD=chronoflow123
MYSQL_ROOT_PASSWORD=root123456

# Admin
PUBLIC_BASE_URL=http://chronoflow-admin:10003
CHRONOFLOW_ADMIN_USERNAME=admin
CHRONOFLOW_ADMIN_PASSWORD=admin123
JWT_SECRET=change-this-jwt-secret
CHRONOFLOW_TOKEN_ENCRYPT_KEY=12345678901234567890123456789012
CHRONOFLOW_CALLBACK_TOKEN=change-this-callback-token
CHRONOFLOW_LOG_DATA_DIR=/app/data
SCHEDULER_TIMEZONE=Asia/Shanghai

# Exec
EXECUTOR_NAME=default-exec
EXECUTOR_TOKEN=default-exec-token
EXECUTOR_DATA_DIR=/app/data
EXECUTOR_TEMP_DIR=/app/data/tmp
EXECUTOR_SHELL_PATH=/bin/bash

# UI -> Admin proxy inside Docker network.
CHRONOFLOW_ADMIN_UPSTREAM=http://chronoflow-admin:10003

# Runtime timezone
TZ=Asia/Shanghai
