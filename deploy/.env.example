# ChronoFlow deployment configuration
# 使用方式：
# 1. cp .env.example .env
# 2. 按需修改 .env
# 3. docker compose -f docker-compose.mysql.yml up -d
# 4. docker compose up -d --build

# =========================
# 镜像配置
# =========================

# Admin 调度器后端镜像地址。
# 仅 docker-compose.image.yml 使用；源码构建部署 docker-compose.yml 会本地 build。
CHRONOFLOW_ADMIN_IMAGE=ghcr.io/your-name/chronoflow-admin:latest

# Exec 执行器后端镜像地址。
# 仅 docker-compose.image.yml 使用；源码构建部署 docker-compose.yml 会本地 build。
CHRONOFLOW_EXEC_IMAGE=ghcr.io/your-name/chronoflow-exec:latest

# UI 前端镜像地址。
# 仅 docker-compose.image.yml 使用；源码构建部署 docker-compose.yml 会本地 build。
CHRONOFLOW_UI_IMAGE=ghcr.io/your-name/chronoflow-ui:latest

# =========================
# 端口配置
# =========================

# UI Web 页面映射到宿主机的端口。
# 浏览器访问地址默认为 http://127.0.0.1:5173。
CHRONOFLOW_UI_PORT=5173

# Admin HTTP API 端口。
# UI/Nginx 会通过该端口访问 Admin，用户也可用该端口 curl API。
CHRONOFLOW_ADMIN_HTTP_PORT=10003

# Admin gRPC 端口。
# 当前主要用于后端服务保留能力，普通用户通常不需要访问。
CHRONOFLOW_ADMIN_GRPC_PORT=11003

# Exec HTTP API 端口。
# Admin 调用执行器 /health、/run、/kill 使用该端口。
CHRONOFLOW_EXEC_HTTP_PORT=10004

# Exec gRPC 端口。
# 当前主要用于后端服务保留能力，普通用户通常不需要访问。
CHRONOFLOW_EXEC_GRPC_PORT=11004

# MySQL 映射到宿主机的端口。
MYSQL_HOST_PORT=3306

# =========================
# MySQL 配置
# =========================

# Admin 连接 MySQL 的主机名。
# 使用 docker-compose.mysql.yml 内置 MySQL 时保持 mysql。
# 使用外部数据库时可改为内网 IP 或 DNS。
DB_HOST=mysql

# Admin 连接 MySQL 的容器内/数据库服务端口。
# 使用 compose 内置 MySQL 时保持 3306；不要填 MYSQL_HOST_PORT。
DB_PORT=3306

# ChronoFlow 使用的数据库名。
# docker-compose.mysql.yml 首次启动时会自动创建该数据库。
DB_NAME=chronoflow

# Admin 连接 MySQL 的用户名。
# docker-compose.mysql.yml 首次启动时会自动创建该用户，因此用户名不能填写root
DB_USER=chronoflow

# Admin 连接 MySQL 的密码。
# 生产环境请修改为强密码。
DB_PASSWORD=chronoflow123

# MySQL root 用户密码。
# 仅 docker-compose.mysql.yml 内置 MySQL 服务使用；使用外部 MySQL 时通常无效。
MYSQL_ROOT_PASSWORD=root123456

# =========================
# Admin 调度器配置
# =========================

# Exec 回调 Admin 时使用的 Admin 内网地址。
# compose 内部署时保持 http://chronoflow-admin:${CHRONOFLOW_ADMIN_HTTP_PORT} 对应端口。
# 如果 Admin 独立部署，需改成 Exec 能访问到的 Admin 地址。
PUBLIC_BASE_URL=http://chronoflow-admin:10003

# Web 登录管理员用户名。
CHRONOFLOW_ADMIN_USERNAME=admin

# Web 登录管理员密码。
# 生产环境必须修改。
CHRONOFLOW_ADMIN_PASSWORD=admin123

# JWT 签名密钥。
# 生产环境必须修改为随机长字符串。
JWT_SECRET=change-this-jwt-secret

# 执行器 token 加密密钥。
# 必须是 32 字节；修改后，已保存的执行器 token 密文将无法用新密钥解密。
CHRONOFLOW_TOKEN_ENCRYPT_KEY=12345678901234567890123456789012

# Exec 回调 Admin 时携带的全局 callback token。
# Admin 校验该 token 后才接受执行结果回调；生产环境必须修改。
CHRONOFLOW_CALLBACK_TOKEN=change-this-callback-token

# Admin 保存完整执行日志文件的目录。
# 容器内默认 /app/data，并通过 Docker volume 持久化。
CHRONOFLOW_LOG_DATA_DIR=/app/data

# Cron 调度时区。
# 默认 Asia/Shanghai；如需 UTC 或其他时区可修改。
SCHEDULER_TIMEZONE=Asia/Shanghai

# =========================
# Exec 执行器配置
# =========================

# 执行器名称。
# 该值用于标识当前 Exec 容器；在 UI 新增执行器时可使用同名。
EXECUTOR_NAME=default-exec

# Admin 调用 Exec 时使用的 token。
# UI 新增执行器时填写的 Token 必须与这里一致；生产环境必须修改。
EXECUTOR_TOKEN=default-exec-token

# Exec 数据目录。
# 用于保存 pending callback 等执行器本地数据，容器内默认 /app/data。
EXECUTOR_DATA_DIR=/app/data

# Exec 临时目录。
# 用于保存临时 Shell 脚本等运行时文件。
EXECUTOR_TEMP_DIR=/app/data/tmp

# Exec 执行 Glue Shell 使用的 shell 路径。
# 默认 /bin/bash；自定义镜像如无 bash，需要改成 /bin/sh 或安装 bash。
EXECUTOR_SHELL_PATH=/bin/bash

# =========================
# UI 配置
# =========================

# UI 容器内 Nginx 转发 /v1 API 到 Admin 的地址。
# compose 内部署时保持 http://chronoflow-admin:${CHRONOFLOW_ADMIN_HTTP_PORT} 对应端口。
CHRONOFLOW_ADMIN_UPSTREAM=http://chronoflow-admin:10003

# =========================
# 运行环境
# =========================

# 容器运行时区。
# 影响容器日志时间；Cron 调度时区以 SCHEDULER_TIMEZONE 为准。
TZ=Asia/Shanghai
